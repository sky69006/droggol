<?xml version="1.0" encoding="utf-8"?>
<odoo>
     <record id="partner_form_view_inherit_webship" model="ir.ui.view">
        <field name="name">res.partner.form.inherit.webship</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Webship" name="Webship">
                    <group string="Velden Webship" name="Webshipgroup">
                        <field name="df_is_supplier_in_webship"></field>
                        <field name="df_is_client_in_webship"></field>
                    </group>
                    <group string="Sync met Webship">
                        <field name="df_url_supplier"/>
                        <field name="df_url_client"></field>
                        <field name="df_standard_internal_note"></field>
                        <field name="df_last_webship_sync" readonly="1"></field>
                        <field name="df_partner_syncresult_webship"  readonly="1" widget="html"></field>
                        <p style="width:320px"><button icon="oi-arrow-right" name="ws_sync_partner" type="object" string="Manueel synchroniseren" class="btn-link"/></p>
                        <p style="width:320px"><button icon="oi-arrow-right" name="ws_match_partner" type="object" string="Manueel matchen" class="btn-link"/></p>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
     <record id="view_partner_tree_inherit_webship" model="ir.ui.view">
        <field name="name">res.partner.list.webship</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//list" position="inside">
                <field name="df_url_client" optional="hide"/>
                <field name="df_url_supplier" optional="hide"/>
                <header>
                    <button name="ws_match_partner"
                            string="Match Webship"
                            type="object"
                            class="btn-primary"
                            icon="fa-link"/>
                    <button name="ws_sync_partner"
                            string="Sync Webship"
                            type="object"
                            class="btn-secondary"
                            icon="fa-refresh"/>
                </header>
            </xpath>
        </field>
    </record>
</odoo>
