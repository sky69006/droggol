<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_order_form_inherit_pickings_button" model="ir.ui.view">
    <field name="name">sale.order.form.inherit.pickings.button</field>
    <field name="model">sale.order</field>
    <field name="inherit_id" ref="sale.view_order_form"/>
    <field name="arch" type="xml">
      <xpath expr="//div[@name='button_box']" position="inside">
        <button name="action_view_pickings"
                type="object"
                class="oe_stat_button">
          <div class="o_stat_info">
               <img src="/webship/static/src/img/webship_vk_16px.png" height="16px" width="16px"
                style="vertical-align:middle;margin-right:4px;" />
            <span class="o_stat_text">Deliveries</span>
            <span class="o_stat_value" field="picking_count"/>
          </div>
        </button>
      </xpath>
    </field>
  </record>

</odoo>
