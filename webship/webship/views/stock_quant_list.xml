<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ========================================================= -->
    <!-- Webship Stock Quant List View                              -->
    <!-- ========================================================= -->
    <!-- ========================================================= -->
<!-- Webship Stock Quant List View                              -->
<!-- ========================================================= -->
<!-- ========================================================= -->
<!-- Webship Stock Quant List View                              -->
<!-- ========================================================= -->
<record id="df_webship_stock_quant_list_view" model="ir.ui.view">
    <field name="name">df.webship.stock.quant.list</field>
    <field name="model">stock.quant</field>
    <field name="priority">50</field>
    <field name="arch" type="xml">
        <list string="Webship Stock"
              create="false"
              edit="false"
              default_order="product_id">

            <!-- Header button (multi-select) -->
            <header>
                <button
                    name="action_apply_webship_stock"
                    type="object"
                    string="Apply Webship Stock to Odoo"
                    class="btn-primary"
                />
            </header>

            <!-- Product & Location -->
            <field name="product_id"/>
            <field name="location_id" optional="hide"/>

            <!-- Odoo stock -->
            <field name="quantity"/>
            <field name="reserved_quantity"/>
            <field name="available_quantity"/>

            <!-- Webship stock (API filled, optional) -->
            <field name="df_webship_totalstock" optional="hide"/>
            <field name="df_webship_reserved" optional="hide"/>
            <field name="df_webship_available_stock" optional="hide"/>

            <!-- Webship sync info -->
            <field name="df_last_check_webship" optional="hide"/>

            <field name="company_id" optional="hide"/>
        </list>
    </field>
</record>




    <!-- ========================================================= -->
    <!-- Webship Stock Action (only Webship locations)              -->
    <!-- ========================================================= -->
    <record id="webship_stock_action" model="ir.actions.act_window">
        <field name="name">Webship Stock</field>
        <field name="res_model">stock.quant</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="df_webship_stock_quant_list_view"/>
        <field name="domain">
            [
                ('location_id.df_is_webship_location', '=', True),
                ('location_id.usage', '=', 'internal')
            ]
        </field>
        <!-- Optional: group by product by default -->
        <!--
        <field name="context">
            {'group_by': 'product_id'}
        </field>
        -->
    </record>

    <!-- ========================================================= -->
    <!-- Webship Stock Menu                                         -->
    <!-- ========================================================= -->
    <menuitem
        id="webship_stock_menu"
        name="Stock"
        parent="webship_root_menu"
        action="webship_stock_action"
        sequence="2"/>

</odoo>