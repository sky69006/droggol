<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="picking_view_inherit_webship" model="ir.ui.view">
        <field name="name">picking.view.inherit.webship</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
             <xpath expr="//notebook" position="inside">
                <page string="Webship" name="Webship" invisible="df_is_webship_source==False and df_is_webship_destination==False" >
                    <group string="Velden Webship" name="Webshipgroup">
                        <field name="df_url_order"></field>
                        <field name="df_url_po"></field>
                        <field name="df_picking_lastsync_webship" readonly="1"></field>
                        <field name="df_picking_syncresult_webship"  readonly="1" widget="html"></field>
                        <field name="df_status_webship" readonly="1"></field>
                        <field name="df_last_changedate_webship" readonly="1"></field>
                        <field name="df_show_webship_page" invisible="1"></field>
                        <field name="df_is_webship_source" invisible="1"></field>
                        <field name="df_is_webship_destination" invisible="1"></field>
                        <p style="width:320px"><button icon="oi-arrow-right" name="ws_sync_picking" type="object" string="Manueel synchroniseren" class="btn-link"/></p>
                    </group>
                </page>
             </xpath>
        </field>
    </record>
</odoo>
