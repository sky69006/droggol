<odoo>
    <data noupdate="1">
        <record id="ir_cron_sync_statussen" model="ir.cron">
            <field name="name">Webship sync statusses</field>
            <field name="model_id" ref="base.model_res_config_settings"/>
            <field name="state">code</field>
            <field name="code">model.ws_sync_statusses_since_last()</field>
            <field name="interval_number">30</field>
            <field name="interval_type">minutes</field>
            <field name="active">True</field>
        </record>
        <record id="ir_cron_sync_statusP" model="ir.cron">
            <field name="name">Webship sync status P</field>
            <field name="model_id" ref="base.model_res_config_settings"/>
            <field name="state">code</field>
            <field name="code">model.ws_sync_all_pickings_statusP()</field>
            <field name="interval_number">30</field>
            <field name="interval_type">minutes</field>
            <field name="active">True</field>
        </record>
    </data>
</odoo>
