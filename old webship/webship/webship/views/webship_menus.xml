<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ✅ Custom Webship Picking List View (not global) -->
    <record id="df_webship_orders_type_list_view" model="ir.ui.view">
        <field name="name">df.webship.orders.type.list</field>
        <field name="model">stock.picking</field>
        <field name="priority">50</field>
        <field name="arch" type="xml">
            <list string="Webship orders" create="false" edit="false" default_order="write_date desc">
                <header>
                    <button name="ws_sync_allpickings" string="Synchronisatie runnen" type="object" class="btn-primary"/>
                    <button name="fetchQuantities" string="Haal hoeveelheden en status op" type="object" class="btn-secondary"/>
                    <button name="make_backorder" string="Manueel backorder maken" type="object" class="btn-secondary"/>
                </header>
                <field name="create_date"/>
                <field name="df_object_in_webship"/>
                <field name="scheduled_date" widget="remaining_days"/>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="df_status_webship" widget="html"/>
                <field name="df_picking_syncresult_webship" widget="html"/>
                <field name="df_url_order_or_po" widget="html"/>
                <field name="sale_id"/>
                <field name="state" widget="badge"
                       decoration-danger="state=='cancel'"
                       decoration-info="state== 'assigned'"
                       decoration-muted="state == 'draft'"
                       decoration-success="state == 'done'"
                       decoration-warning="state not in ('draft','cancel','done','assigned')"/>
            </list>
        </field>
    </record>

    <!-- ✅ Custom Webship Action using the custom view -->
    <record id="webship_orders_action" model="ir.actions.act_window">
    <field name="name">Webship orders</field>
    <field name="res_model">stock.picking</field>
    <field name="view_mode">list,form</field>
    <field name="view_id" ref="df_webship_orders_type_list_view"/>
    <field name="domain">
  [
    '&amp;',
      '|',
        ('df_is_webship_source', '=', True),
        ('df_is_webship_destination', '=', True),
      ('state', 'in', ['confirmed', 'assigned', 'done'])
  ]
</field>
    </record>

    <!-- ✅ Webship Menu -->
    <menuitem id="webship_root_menu" name="Webship" web_icon="webship,static/description/icon.png"/>
    <menuitem name="Orders" id="webship_order_sub_root" parent="webship_root_menu" action="webship_orders_action" sequence="1"/>

</odoo>
